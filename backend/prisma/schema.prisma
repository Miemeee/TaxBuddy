generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  user_id            Int      @id @default(autoincrement())
  name               String
  email              String   @unique
  phone_number       String?
  password_hash      String
  incomeChannels     IncomeChannel[]
  allow_notifications Boolean @default(false)
    has_onboarded     Boolean  @default(false)

  transactions       Transaction[]
  taxRecords         TaxRecord[]
  userDeductions     UserDeduction[]
}

model Document {
  document_id Int    @id @default(autoincrement())
  file_path   String

  transactions Transaction[]
}

model Transaction {
  transaction_id  Int      @id @default(autoincrement())
  user_id         Int
  amount          Float
  category        String
  description     String?
  document_id     Int?
  date            DateTime
  transaction_type String
  wallet_type     String?
  profession_id   Int?

  user     User     @relation(fields: [user_id], references: [user_id])
  document Document? @relation(fields: [document_id], references: [document_id])
}

model Deduction {
  deduction_id   Int     @id @default(autoincrement())
  deduction_name String
  max_limit      Float
  tax_year_applies Int

  userDeductions UserDeduction[]
}

model UserDeduction {
  user_deduction_id Int @id @default(autoincrement())
  user_id           Int
  deduction_id      Int
  tax_year          Int
  amount_claimed    Float
  transaction_id    Int?

  user      User      @relation(fields: [user_id], references: [user_id])
  deduction Deduction @relation(fields: [deduction_id], references: [deduction_id])
}

model TaxRecord {
  tax_record_id            Int     @id @default(autoincrement())
  user_id                  Int
  tax_year                 Int
  total_business_income    Float
  total_deductions_claimed Float
  net_income               Float
  tax_due                  Float
  status                   String

  user User @relation(fields: [user_id], references: [user_id])
}

model IncomeChannel {
  id       Int    @id @default(autoincrement())
  channel  String

  user     User   @relation(fields: [user_id], references: [user_id])
  user_id  Int
}